{
  "name": "npm-plugin-kit",
  "type": "module",
  "version": "0.6.2",
  "packageManager": "pnpm@11.5.1",
  "description": "A simple and powerful npm-based plugin system",
  "author": "imba97",
  "license": "MIT",
  "homepage": "https://github.com/imba97/npm-plugin-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com:imba97/npm-plugin-kit.git"
  },
  "bugs": {
    "url": "https://github.com/imba97/npm-plugin-kit/issues"
  },
  "keywords": [
    "npm",
    "plugin",
    "kit"
  ],
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "prepare": "simple-git-hooks",
    "stub": "unbuild --stub",
    "build": "unbuild",
    "test": "vitest --run",
    "lint": "eslint --cache",
    "release": "bumpp"
  },
  "dependencies": {
    "importx": "^0.5.2",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "nano-staged": "^1.0.2",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.8"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm nano-staged"
  },
  "nano-staged": {
    "*": "eslint --cache --fix"
  }
}
